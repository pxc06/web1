new Vue({
    el: '#app',
    data: {
        showLogin: false,
        showRegister: false,
        currentUser: null    // 当前登录用户
    },
    methods: {
        handleLearnNow: function() {
            console.log('[事件] 用户点击了"马上学习"');
        },
        handleLearnMore: function(title) {
            console.log('[事件] 用户想了解更多:', title);
        },
        handleLoginSuccess: function(userData) {
            this.currentUser = userData;
            console.log('[事件] 登录成功:', userData);
        },
        handleRegisterSuccess: function(userData) {
            console.log('[事件] 注册成功:', userData);
            // 注册成功后自动切换到登录
            this.showRegister = false;
            this.showLogin = true;
        },
        handleLogout: function() {
            this.currentUser = null;
            alert('👋 已退出登录！');
        }
    },
    // 页面加载时检查是否有已登录用户（模拟 session）
    mounted: function() {
        var savedUser = localStorage.getItem('artech_current_user');
        if (savedUser) {
            try {
                this.currentUser = JSON.parse(savedUser);
            } catch(e) {
                localStorage.removeItem('artech_current_user');
            }
        }
    },
    watch: {
        currentUser: function(newVal) {
            if (newVal) {
                localStorage.setItem('artech_current_user', JSON.stringify(newVal));
            } else {
                localStorage.removeItem('artech_current_user');
            }
        }
    }
});
</script>

