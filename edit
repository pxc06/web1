// 组件：LoginModal（登录弹窗）
// ====================================================================
Vue.component('login-modal', {
    template: `
        <div class="modal-mask" @click.self="$emit('close')">
            <div class="modal-container">
                <button class="close-btn" @click="$emit('close')">&times;</button>
                <h3>🔑 用户登录</h3>

                <div v-if="alert.show" class="alert-msg" :class="'alert-' + alert.type">
                    {{ alert.message }}
                </div>

                <div class="form-group">
                    <label>用户名</label>
                    <input type="text"
                           class="form-control"
                           v-model.trim="form.username"
                           placeholder="请输入用户名"
                           @keyup.enter="handleLogin">
                </div>
                <div class="form-group">
                    <label>密码</label>
                    <input type="password"
                           class="form-control"
                           v-model.trim="form.password"
                           placeholder="请输入密码"
                           @keyup.enter="handleLogin">
                </div>

                <button class="btn-submit" @click="handleLogin" :disabled="loading">
                    {{ loading ? '⏳ 登录中...' : '🚀 登录' }}
                </button>

                <p class="switch-text">
                    还没有账号？<a @click="$emit('switch-to-register')">立即注册</a>
                </p>
            </div>
        </div>
    `,
    data: function() {
        return {
            form: { username: '', password: '' },
            loading: false,
            alert: { show: false, type: '', message: '' }
        };
    },
    methods: {
        showAlert: function(type, msg) {
            this.alert = { show: true, type: type, message: msg };
        },
        handleLogin: function() {
            var self = this;
            self.alert.show = false;

            if (!self.form.username || !self.form.password) {
                self.showAlert('error', '⚠️ 请填写完整的登录信息！');
                return;
            }

            self.loading = true;

            // 调用 API（当前为模拟，部署后对接 SSM 后端）
            ApiService.login({
                username: self.form.username,
                password: self.form.password
            })
            .then(function(response) {
                self.loading = false;
                var res = response.data;

                if (res.code === 200) {
                    self.showAlert('success', '✅ ' + res.message);
                    setTimeout(function() {
                        self.$emit('login-success', res.data);
                        self.$emit('close');
                        self.form = { username: '', password: '' };
                        self.alert.show = false;
                    }, 800);
                } else {
                    self.showAlert('error', '❌ ' + res.message);
                }
            })
            .catch(function(error) {
                self.loading = false;
                self.showAlert('error', '❌ 网络错误，请检查后端服务是否启动！');
                console.error('登录失败:', error);
            });
        }
    }
});

// ====================================================================
// 组件：RegisterModal（注册弹窗）
// ====================================================================
Vue.component('register-modal', {
    template: `
        <div class="modal-mask" @click.self="$emit('close')">
            <div class="modal-container">
                <button class="close-btn" @click="$emit('close')">&times;</button>
                <h3>📝 用户注册</h3>

                <div v-if="alert.show" class="alert-msg" :class="'alert-' + alert.type">
                    {{ alert.message }}
                </div>

                <div class="form-group">
                    <label>用户名</label>
                    <input type="text"
                           class="form-control"
                           v-model.trim="form.username"
                           placeholder="请输入用户名"
                           @keyup.enter="handleRegister">
                </div>
                <div class="form-group">
                    <label>邮箱</label>
                    <input type="email"
                           class="form-control"
                           v-model.trim="form.email"
                           placeholder="请输入邮箱">
                </div>
                <div class="form-group">
                    <label>密码</label>
                    <input type="password"
                           class="form-control"
                           v-model.trim="form.password"
                           placeholder="请输入密码（至少6位）">
                </div>
                <div class="form-group">
                    <label>确认密码</label>
                    <input type="password"
                           class="form-control"
                           v-model.trim="form.confirmPassword"
                           placeholder="请再次输入密码"
                           @keyup.enter="handleRegister">
                </div>

                <button class="btn-submit" @click="handleRegister" :disabled="loading">
                    {{ loading ? '⏳ 注册中...' : '✨ 立即注册' }}
                </button>

                <p class="switch-text">
                    已有账号？<a @click="$emit('switch-to-login')">立即登录</a>
                </p>
            </div>
        </div>
    `,
    data: function() {
        return {
            form: {
                username: '',
                email: '',
                password: '',
                confirmPassword: ''
            },
            loading: false,
            alert: { show: false, type: '', message: '' }
        };
    },
    methods: {
        showAlert: function(type, msg) {
            this.alert = { show: true, type: type, message: msg };
        },
        handleRegister: function() {
            var self = this;
            self.alert.show = false;

            // 表单验证
            if (!self.form.username || !self.form.email ||
                !self.form.password || !self.form.confirmPassword) {
                self.showAlert('error', '⚠️ 请填写所有注册信息！');
                return;
            }

            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(self.form.email)) {
                self.showAlert('error', '❌ 请输入有效的邮箱地址！');
                return;
            }

            if (self.form.password.length < 6) {
                self.showAlert('error', '❌ 密码长度不能少于6位！');
                return;
            }

            if (self.form.password !== self.form.confirmPassword) {
                self.showAlert('error', '❌ 两次输入的密码不一致！');
                return;
            }

            // 调用 API（当前为模拟，部署后对接 SSM 后端）
            self.loading = true;

            ApiService.register({
                username: self.form.username,
                email: self.form.email,
                password: self.form.password
            })
            .then(function(response) {
                self.loading = false;
                var res = response.data;
                self.showAlert('success', '✅ ' + res.message);

                setTimeout(function() {
                    self.$emit('register-success', res.data);
                    self.$emit('close');
                    self.form = { username: '', email: '', password: '', confirmPassword: '' };
                    self.alert.show = false;
                }, 1500);
            })
            .catch(function(error) {
                self.loading = false;
                var msg = '注册失败，请重试！';
                if (error.response && error.response.data) {
                    msg = error.response.data.message || msg;
                }
                self.showAlert('error', '❌ ' + msg);
                console.error('注册失败:', error);
            });
        }
    }
});

