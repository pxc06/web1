            position: relative;
            overflow: hidden;
        }
        .hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(255,255,255,0.07) 1px, transparent 1px);
            background-size: 28px 28px;
        }
        .hero::after {
            content: '';
            position: absolute;
            bottom: -60px;
            left: -10%;
            width: 120%;
            height: 120px;
            background: #f4f7fa;
            border-radius: 50% 50% 0 0;
