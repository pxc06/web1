<script>
// ====================================================================
// API 服务封装（模拟后端，使用 localStorage）
// 实际部署时替换为真实 axios 请求
// ====================================================================
var API_BASE = '/ssm-user-system/api'; // 部署后指向 SSM 后端

var ApiService = {

    /**
     * 模拟用户注册（localStorage）
     * 对应后端：POST /api/user/register
     */
    register: function(userData) {
        return new Promise(function(resolve, reject) {
            setTimeout(function() {
                var users = JSON.parse(localStorage.getItem('artech_users') || '[]');

                // 检查用户名是否已存在
                var exists = users.find(function(u) {
                    return u.username === userData.username;
                });
                if (exists) {
                    reject({ response: { data: { code: 400, message: '用户名 "' + userData.username + '" 已存在！' } } });
                    return;
                }

                // 创建新用户
                var newUser = {
                    id: Date.now(),
                    username: userData.username,
                    email: userData.email,
                    createTime: new Date().toISOString()
                };
                users.push({
                    username: userData.username,
                    password: userData.password,
                    email: userData.email
                });
                localStorage.setItem('artech_users', JSON.stringify(users));

                resolve({ data: { code: 200, message: '注册成功！', data: newUser } });
            }, 600);
        });
    },

    /**
     * 模拟用户登录（localStorage）
     * 对应后端：POST /api/user/login
     */
    login: function(userData) {
        return new Promise(function(resolve, reject) {
            setTimeout(function() {
                var users = JSON.parse(localStorage.getItem('artech_users') || '[]');
                var user = users.find(function(u) {
                    return u.username === userData.username && u.password === userData.password;
                });

                if (user) {
                    resolve({
                        data: {
                            code: 200,
                            message: '登录成功！',
                            data: { id: Date.now(), username: user.username, email: user.email }
                        }
                    });
                } else {
                    resolve({ data: { code: 400, message: '用户名或密码错误！' } });
                }
            }, 500);
        });
    },

    /**
     * 获取用户列表
     * 对应后端：GET /api/user/list
     */
    getUsers: function() {
        return new Promise(function(resolve) {
            var users = JSON.parse(localStorage.getItem('artech_users') || '[]');
            resolve({ data: { code: 200, message: '查询成功', data: users.length } });
        });
    }
};

